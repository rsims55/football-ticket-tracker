# local virtualenvs (any name): .venv (Linux/macOS), .venv_win (Windows)
venv/
.env/
.venv/
.venv*/
env*/
ENV*/

# poetry / pip-tools artifacts
poetry.lock
pip-wheel-metadata/

# --- Editors/IDEs ---
.vscode/
.idea/
*.code-workspace

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs & runtime files ---
logs/
*.log
*.pid
*.sqlite
.tmp/
tmp/

# --- Secrets & environment ---
.env
.env.*
secrets.txt
secrets/*.json
*.key
*.pem

# --- Packaging outputs ---
dist/
build/
packaging/dist/
packaging/*.ext4
packaging/*.zip

# --- Windows Task Scheduler exports ---
packaging/windows/task/*.xml
packaging/windows/task/*.sch

# --- App cache & user-local mirrors (Windows/Linux) ---
